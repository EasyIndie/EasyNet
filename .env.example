# EasyNet 环境变量配置模板
# 复制此文件为 .env 并根据需要修改配置，部署脚本会自动读取此文件。
#
# 使用方式：
#   cp .env.example .env
#   ./scripts/deploy.sh
#
# 或直接传环境变量：
#   EASYNET_DOMAIN=proxy.example.com ./scripts/deploy.sh
#
# 大多数变量有合理的默认值，你通常只需配置 # 1. 必填配置 即可。

# ---------------------------------------------------------
# 1. 必填配置
# ---------------------------------------------------------

# 域名（必填——Hysteria2 需要域名，Edge Gateway 自动签发证书并生成订阅链接）
# 请确保此域名已经 A 记录解析到当前服务器公网 IP。
# EASYNET_DOMAIN=proxy.example.com

# 部署策略（默认 balanced，可选 strict / balanced / compat）
# strict:   仅部署 Xray+Reality（极致抗 DPI）
# balanced: Xray+Reality + Hysteria2（均衡，推荐默认）
# compat:   全部已发现模块
EASYNET_PROFILE=balanced

# 也可直接指定单个模块（优先级高于 PROFILE）：
# EASYNET_MODULE=xray-reality

# ---------------------------------------------------------
# 2. 常用调优
# ---------------------------------------------------------
# 以下变量可以按需调整，不设置也使用合理的默认值。

# Reality 传输方式：tcp（默认，推荐）或 xhttp（HTTP/3 伪装）
# EASYNET_REALITY_TRANSPORT=tcp
# EASYNET_REALITY_TRANSPORT=xhttp

# Reality TLS 指纹（默认 chrome，可选: firefox, ios, edge, random, 或留空使用 Go 默认）
# EASYNET_REALITY_FINGERPRINT=chrome

# Reality 时间偏移限制（毫秒），默认 1800000 (30分钟)，设为 0 禁用
# EASYNET_REALITY_MAX_TIME_DIFF=1800000

# Hysteria2 端口跳跃（默认 20000-30000/udp），留空禁用
EASYNET_HYSTERIA2_PORT_HOPPING=20000-30000

# 手动指定公网 IP（覆盖自动检测，多网卡或 NAT 场景使用）
# EASYNET_PUBLIC_IP=203.0.113.1

# 抗 DPI 提示：
#   1. 强烈建议设置 EASYNET_REALITY_DEST 为同机房邻居域名（bgp.tools 可查）
#   2. EASYNET_REALITY_FINGERPRINT=random 可每连接轮换指纹，降低单一指纹被特征化风险
#   3. 如果使用 sing-box 客户端，XHTTP 传输会被自动降级为 TCP
#   4. maxTimeDiff 默认 30 分钟，防止时钟偏移导致的拒绝服务

# ---------------------------------------------------------
# 3. 部署选择（仅自动化部署时需要）
# ---------------------------------------------------------
# 以下变量用于非交互式部署（CI/CD、脚本调用）。
# 手动部署时脚本会提示选择，无需设置。
#
# 编号按协议抗 DPI 能力从高到低排序（与交互菜单一致）:
#   0=全部 1=xray-reality 2=hysteria2 3=shadowsocks 4=wireguard
# EASYNET_SERVICE_CHOICE=0

# 安全回滚：部署失败时自动恢复 state 目录
# EASYNET_AUTO_ROLLBACK=true
# 严格预检：部署前检查 DNS 解析、端口可用性等
# EASYNET_STRICT_PRECHECK=false

# ---------------------------------------------------------
# 4. 卸载配置（独立变量空间，用于自动化卸载）
# ---------------------------------------------------------
# 编号与部署一致（协议按抗 DPI 排序），edge 作为暴露模块排在最后:
#   0=全部 1=xray-reality 2=hysteria2 3=shadowsocks 4=wireguard 5=edge
# EASYNET_UNINSTALL_CHOICE=0
# EASYNET_UNINSTALL_MODULE=xray-reality
# EASYNET_UNINSTALL_KEEP_CONFIG=true
# EASYNET_UNINSTALL_PURGE_PACKAGES=true

# ---------------------------------------------------------
# 5. 高级配置
# ---------------------------------------------------------
# 以下变量很少需要修改，取消注释并修改值即可生效。

# --- 协议端口 ---
# EASYNET_REALITY_PORT=8443
# EASYNET_HYSTERIA2_PORT=443
# EASYNET_SHADOWSOCKS_PORT=8388
# EASYNET_WIREGUARD_PORT=51820

# --- Reality 细节 ---
# 伪装目标域名（强烈建议改为同机房邻居域名，使用 bgp.tools 查找同 ASN 域名）
# 避免使用: apple.com, google.com, microsoft.com, icloud.com（已被重点监控）
# EASYNET_REALITY_DEST=www.bing.com:443
# EASYNET_REALITY_SERVER_NAME=www.bing.com,www.cloudflare.com
# EASYNET_REALITY_XHTTP_MODE=stream-one
# EASYNET_REALITY_XMUX_CONCURRENCY=0
# EASYNET_REALITY_XMUX_CONN_IDLE=60
# 指纹和时间偏移见第2节"常用调优"

# --- Hysteria2 细节 ---
# 以下证书变量可覆盖 Edge 统一证书，为 Hysteria2 使用独立证书
# EASYNET_HYSTERIA2_CERT_FILE=  （默认使用 Edge 统一证书）
# EASYNET_HYSTERIA2_KEY_FILE=   （默认使用 Edge 统一证书）
# EASYNET_HYSTERIA2_PORT_HOP_INTERVAL=30s
# EASYNET_HYSTERIA2_PASSWORD=   （随机生成，留空自动生成）
# EASYNET_HYSTERIA2_OBFS_PASSWORD=   （随机生成，留空自动生成）
# EASYNET_HYSTERIA2_MASQUERADE_URL=https://www.bing.com/

# --- WireGuard 细节 ---
# EASYNET_WIREGUARD_OBFS=true
# EASYNET_WIREGUARD_JC=5
# EASYNET_WIREGUARD_JMIN=50
# EASYNET_WIREGUARD_JMAX=1000
# EASYNET_WIREGUARD_SERVER_IP=10.0.0.1/24
# EASYNET_WIREGUARD_CLIENT=client1

# --- Edge Gateway ---
# EASYNET_EDGE_HTTP_PORT=80
# EASYNET_EDGE_HTTPS_PORT=443
# EASYNET_EDGE_MASQUERADE_URL=https://www.bing.com
# EASYNET_EDGE_CERT_DIR=/etc/ssl/easynet-edge
# EASYNET_EDGE_CERT_FILE=/etc/ssl/easynet-edge/fullchain.crt
# EASYNET_EDGE_KEY_FILE=/etc/ssl/easynet-edge/private.key
# EASYNET_EDGE_STATE_DIR=/var/lib/easynet/exposure/edge
# EASYNET_EDGE_RENEW_HOOK=  （默认使用内置 cert_renew_hook.sh）
# EASYNET_SUBSCRIPTION_PATH_PREFIX=/mysecret
# EASYNET_SUBSCRIPTION_DIRECT_PATHS=true
# EASYNET_SUBSCRIPTION_SCHEME=https
# EASYNET_SUBSCRIPTION_URL_PORT=  （默认使用 Edge HTTPS 端口）
# EASYNET_SUBSCRIPTION_ROTATION_GRACE=false
# EASYNET_SKIP_NGINX_RELOAD=false

# --- 订阅域名（与部署域名不同时使用） ---
# EASYNET_SUBSCRIPTION_DOMAIN=proxy.example.com

# --- 状态和输出目录 ---
# EASYNET_STATE_DIR=/var/lib/easynet
# EASYNET_WEB_ROOT=/var/www/html

# --- SHA256 供应链校验 ---
# EASYNET_XRAY_VERSION=26.3.27
# EASYNET_ACME_INSTALL_SHA256=
# EASYNET_XRAY_INSTALL_SHA256=
# EASYNET_HYSTERIA2_INSTALL_SHA256=
# EASYNET_SHADOWSOCKS_INSTALL_SHA256=
# EASYNET_SINGBOX_INSTALL_SHA256=

# --- sing-box 客户端（端设备安装时使用） ---
# EASYNET_SINGBOX_MODE=mixed
# EASYNET_SINGBOX_INSTALL_DIR=/usr/local/bin
# EASYNET_SINGBOX_CONFIG_DIR=/etc/sing-box
# EASYNET_SINGBOX_STATE_DIR=/etc/easynet
# EASYNET_SINGBOX_SERVICE_NAME=easynet-singbox
# EASYNET_SINGBOX_UPDATE_NAME=easynet-singbox-update
# EASYNET_SINGBOX_DOWNLOAD_URL=  （默认从 GitHub Releases 自动检测）
# EASYNET_SINGBOX_RELEASE_API=https://api.github.com/repos/SagerNet/sing-box/releases/latest
# EASYNET_SINGBOX_PROBE_URL=https://www.gstatic.com/generate_204

# --- 系统维护 ---
# EASYNET_JOURNALD_MAX_USE=500M
# EASYNET_NGINX_LOGROTATE_FILE=/etc/logrotate.d/easynet-nginx
