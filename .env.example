# EasyNet 环境变量配置模板
# 复制此文件为 .env 并根据需要修改配置，部署脚本会自动读取此文件。

# ---------------------------------------------------------
# 1. 部署选择
# ---------------------------------------------------------
# 优先级：EASYNET_PROFILE > EASYNET_MODULE > EASYNET_SERVICE_CHOICE。
#
# EASYNET_SERVICE_CHOICE:
# 0: 全部部署
# 1: Xray+Reality
# 2: Hysteria2
# 3: Shadowsocks 2022
# 4: WireGuard
# 5: 退出安装
#
# 编号 1-4 按安全性和抗 DPI 能力从高到低排序。
EASYNET_SERVICE_CHOICE=0

# 按策略部署，可选：strict / balanced / compat。
# strict: xray-reality
# balanced: xray-reality + hysteria2
# compat: 全部模块
# EASYNET_PROFILE=balanced

# 按单个模块部署，可选：
# xray-reality / hysteria2 / shadowsocks / wireguard
# EASYNET_MODULE=xray-reality

# ---------------------------------------------------------
# 1.2 安全回滚
# ---------------------------------------------------------
# 部署前自动备份 state 目录，部署过程中出错时自动恢复。
# 默认关闭，设置为 true 启用。
# EASYNET_AUTO_ROLLBACK=true

# ---------------------------------------------------------
# 1.3 卸载选择
# ---------------------------------------------------------
# 卸载脚本使用独立变量，避免误用部署选择。
# EASYNET_UNINSTALL_CHOICE:
# 0: 卸载全部协议与 Edge Gateway
# 1: Xray+Reality
# 2: Hysteria2
# 3: Shadowsocks 2022
# 4: WireGuard
# 5: 仅清理 Edge Gateway 与订阅文件
# 6: 退出卸载
# EASYNET_UNINSTALL_CHOICE=0

# 按单个模块卸载，可选：
# xray-reality / hysteria2 / shadowsocks / wireguard / edge
# EASYNET_UNINSTALL_MODULE=xray-reality

# 默认卸载 EasyNet 生成的配置、服务文件、metadata 与订阅文件。
# 如需保留配置用于迁移或排障，设置为 true。
# EASYNET_UNINSTALL_KEEP_CONFIG=false

# 默认不卸载 apt 包，避免影响系统上其它服务。
# 确认这些包只由 EasyNet 使用时，可设置为 true。
# EASYNET_UNINSTALL_PURGE_PACKAGES=false

# ---------------------------------------------------------
# 2. 域名配置
# ---------------------------------------------------------
# Hysteria2 需要域名。配置域名后会自动启用 Edge Gateway 并打印订阅链接和二维码。
# 请确保此域名已经 A 记录解析到当前服务器公网 IP。
# EASYNET_DOMAIN=proxy.example.com

# 如果订阅域名与部署域名不同，可单独指定。
# EASYNET_SUBSCRIPTION_DOMAIN=proxy.example.com
# Edge Gateway 默认占用 TCP/443，并使用首次部署时生成的稳定随机路径承载订阅。
# 可运行 ./scripts/show_subscription.sh 随时重新显示订阅链接和二维码。
# 如果 EASYNET_DOMAIN 与 EASYNET_SUBSCRIPTION_DOMAIN 不同，两者都需要解析到服务器。
# 如确需改端口，可使用高级变量 EASYNET_EDGE_HTTPS_PORT。
# Edge Gateway 根路径默认反代到 https://www.bing.com 消除指纹，
# 可通过 EASYNET_EDGE_MASQUERADE_URL 自定义伪装目标。
# EASYNET_EDGE_MASQUERADE_URL=https://www.bing.com

# ---------------------------------------------------------
# 3. 可选：公共状态和输出目录
# ---------------------------------------------------------
# EASYNET_STATE_DIR=/var/lib/easynet
# EASYNET_WEB_ROOT=/var/www/html

# ---------------------------------------------------------
# 4. 可选：协议参数
# ---------------------------------------------------------
# Xray Reality
# EASYNET_REALITY_PORT=8443
# EASYNET_REALITY_DEST=www.microsoft.com:443
# EASYNET_REALITY_SERVER_NAME 支持逗号分隔多个目标，默认 microsoft.com,cloudflare.com
# EASYNET_REALITY_SERVER_NAME=www.microsoft.com,cloudflare.com,www.apple.com
# EASYNET_REALITY_TRANSPORT 可选 tcp（默认）或 xhttp（HTTP/3 伪装传输）
# EASYNET_REALITY_TRANSPORT=xhttp
# EASYNET_REALITY_XHTTP_MODE 可选 auto（默认）/ stream-one / stream-up / packet-up
# EASYNET_REALITY_XHTTP_MODE=auto
# EASYNET_REALITY_XMUX_CONCURRENCY XMUX 多路复用并发数（0=禁用，默认）
# EASYNET_REALITY_XMUX_CONCURRENCY=0
# EASYNET_REALITY_FRAGMENT Finalmask 包分片混淆（默认 tlshello，设为空禁用）
# EASYNET_REALITY_FRAGMENT=tlshello
# EASYNET_REALITY_FRAGMENT_LENGTH 分片长度范围（默认 100-200 字节）
# EASYNET_REALITY_FRAGMENT_INTERVAL 分片间隔范围（默认 10-20 毫秒）

# Hysteria2
# EASYNET_HYSTERIA2_PORT=443
# EASYNET_HYSTERIA2_PORT_HOPPING 端口跳变范围（如 "20000-30000"），留空禁用
# EASYNET_HYSTERIA2_PORT_HOPPING=20000-30000
# EASYNET_HYSTERIA2_PORT_HOP_INTERVAL 跳变间隔，默认 30s
# EASYNET_HYSTERIA2_PORT_HOP_INTERVAL=30s

# Shadowsocks 2022 Edition (shadowsocks-rust)
# EASYNET_SHADOWSOCKS_PORT=8388
# EASYNET_SHADOWSOCKS_INSTALL_SHA256 可选，用于校验 shadowsocks-rust 二进制包

# WireGuard
# EASYNET_WIREGUARD_PORT=51820
# EASYNET_WIREGUARD_OBFS AmneziaWG 混淆（默认 true，启用 Jc/Jmin/Jmax 垃圾包填充）
# EASYNET_WIREGUARD_OBFS=true
# EASYNET_WIREGUARD_JC 垃圾包数量（默认 5）
# EASYNET_WIREGUARD_JMIN 最小垃圾包大小（默认 50 字节）
# EASYNET_WIREGUARD_JMAX 最大垃圾包大小（默认 1000 字节）

# ---------------------------------------------------------
# 5. 可选：安装脚本/安装包 SHA256 校验
# ---------------------------------------------------------
# 默认使用 HTTPS 下载官方安装脚本或发布包。
# 如需进一步收紧供应链风险，可填写对应 SHA256，下载后会先校验再执行或安装。
# EASYNET_ACME_INSTALL_SHA256=
# EASYNET_XRAY_INSTALL_SHA256=
# EASYNET_HYSTERIA2_INSTALL_SHA256=
