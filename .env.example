# EasyNet 环境变量配置模板
# 复制此文件为 .env 并根据需要修改配置，部署脚本会自动读取此文件。

# ---------------------------------------------------------
# 1. 部署选择
# ---------------------------------------------------------
# 优先级：EASYNET_PROFILE > EASYNET_MODULE > EASYNET_SERVICE_CHOICE。
#
# EASYNET_SERVICE_CHOICE:
# 0: 全部部署
# 1: Xray+Reality
# 2: Hysteria2
# 3: Trojan-Go
# 4: V2Ray
# 5: Shadowsocks-libev
# 6: WireGuard
# 7: 退出安装
#
# 编号 1-6 按安全性和抗 DPI 能力从高到低排序。
EASYNET_SERVICE_CHOICE=0

# 按策略部署，可选：strict / balanced / compat。
# strict: xray-reality
# balanced: xray-reality + hysteria2
# compat: 全部模块
# EASYNET_PROFILE=balanced

# 按单个模块部署，可选：
# xray-reality / hysteria2 / trojan-go / v2ray / shadowsocks / wireguard
# EASYNET_MODULE=xray-reality

# ---------------------------------------------------------
# 1.1 卸载选择
# ---------------------------------------------------------
# 卸载脚本使用独立变量，避免误用部署选择。
# EASYNET_UNINSTALL_CHOICE:
# 0: 卸载全部协议与 EasyNet Nginx 暴露层
# 1: Xray+Reality
# 2: Hysteria2
# 3: Trojan-Go
# 4: V2Ray
# 5: Shadowsocks-libev
# 6: WireGuard
# 7: 仅清理 EasyNet Nginx 暴露层与订阅文件
# 8: 仅清理独立订阅承载与订阅文件
# 9: 退出卸载
# EASYNET_UNINSTALL_CHOICE=0

# 按单个模块卸载，可选：
# xray-reality / hysteria2 / trojan-go / v2ray / shadowsocks / wireguard / nginx-exposure / subscription-exposure
# EASYNET_UNINSTALL_MODULE=xray-reality

# 默认卸载 EasyNet 生成的配置、服务文件、metadata 与订阅文件。
# 如需保留配置用于迁移或排障，设置为 true。
# EASYNET_UNINSTALL_KEEP_CONFIG=false

# 默认不卸载 apt 包，避免影响系统上其它服务。
# 确认这些包只由 EasyNet 使用时，可设置为 true。
# EASYNET_UNINSTALL_PURGE_PACKAGES=false

# ---------------------------------------------------------
# 2. 域名配置
# ---------------------------------------------------------
# Trojan-Go / V2Ray / Hysteria2 需要域名。
# 配置域名后会自动启用独立订阅承载并打印订阅链接和二维码。
# 请确保此域名已经 A 记录解析到当前服务器公网 IP。
# EASYNET_DOMAIN=proxy.example.com

# 如果订阅域名与部署域名不同，可单独指定。
# EASYNET_SUBSCRIPTION_DOMAIN=proxy.example.com

# ---------------------------------------------------------
# 3. 可选：公共状态和输出目录
# ---------------------------------------------------------
# EASYNET_STATE_DIR=/var/lib/easynet
# EASYNET_WEB_ROOT=/var/www/html
# EASYNET_NGINX_STATE_DIR=/var/lib/easynet/exposure/nginx

# ---------------------------------------------------------
# 4. 可选：协议参数
# ---------------------------------------------------------
# Xray Reality
# EASYNET_REALITY_PORT=8443
# EASYNET_REALITY_DEST=www.microsoft.com:443
# EASYNET_REALITY_SERVER_NAME=www.microsoft.com

# Hysteria2
# EASYNET_HYSTERIA2_PORT=443

# V2Ray
# EASYNET_V2RAY_MODE=standalone
# EASYNET_V2RAY_PORT=443

# Shadowsocks
# EASYNET_SHADOWSOCKS_PORT=8388

# WireGuard
# EASYNET_WIREGUARD_PORT=51820
