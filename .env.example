# EasyNet 环境变量配置模板
# 复制此文件为 .env 并根据需要修改配置，部署脚本会自动读取此文件。

# ---------------------------------------------------------
# 1. 部署服务选择 (EASYNET_SERVICE_CHOICE)
# ---------------------------------------------------------
# 1: 部署 Trojan-Go (推荐)
# 2: 部署 V2Ray
# 3: 部署 Shadowsocks-libev
# 4: 部署 WireGuard
# 5: 部署 Xray+Reality
# 6: 全部部署
# 7: 退出安装
# 留空或注释此行则在执行脚本时交互式选择。
EASYNET_SERVICE_CHOICE=6

# ---------------------------------------------------------
# 2. 域名配置 (EASYNET_DOMAIN)
# ---------------------------------------------------------
# 用于申请 TLS 证书（Trojan-Go 和 V2Ray 需要使用）。
# 请确保此域名已经 A 记录解析到当前服务器的公网 IP。
# 如果不部署 Trojan-Go 或 V2Ray，可以留空。
EASYNET_DOMAIN=proxy.example.com
